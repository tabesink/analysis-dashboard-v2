{
  "name": "client",
  "version": "1.3.7",
  "private": true,
  "scripts": {
    "generate:settings": "node scripts/generate-settings.js",
    "generate:version": "node scripts/generate-version.js",
    "generate:filters": "node scripts/generate-filters.js",
    "generate": "npm run generate:version && npm run generate:filters && npm run generate:settings",
    "dev": "npm run generate && (next dev -H 127.0.0.1 -p 3001 || next dev -H 127.0.0.1 -p 3002)",
    "build": "npm run generate && next build",
    "prepare:standalone": "mkdir -p .next/standalone/.next .next/standalone/public && rm -rf .next/standalone/.next/static && cp -R .next/static .next/standalone/.next/static && cp -R public/. .next/standalone/public/",
    "start": "npm run prepare:standalone && HOSTNAME=0.0.0.0 PORT=3001 node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "memory:benchmark": "node scripts/memory-benchmark.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "geist": "^1.7.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "fallow": "^2.94.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "^8.5.14"
  }
}
