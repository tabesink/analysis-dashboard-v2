{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/workers/**/*.{ts,tsx}"
  ],
  // Auto-generated by scripts/generate-{filters,settings,version}.js — do not prune exports
  "ignorePatterns": [
    "src/config/filters.ts",
    "src/config/settings.ts",
    "src/config/version.ts",
    // Feature/public barrel surfaces are intentionally wider than
    // current in-repo usage; keep them out of dead-export noise.
    "src/components/charts/index.ts",
    "src/components/edit-metadata/index.ts",
    "src/components/upload/index.ts"
  ],
  // Next.js requires react-dom at runtime; Fallow cannot see framework entry usage
  "ignoreDependencies": ["react-dom"],
  "ignoreExportsUsedInFile": true,
  "duplicates": {
    // Hide pair-only clones; focus on widespread copy-paste
    // worth refactoring. Lower to 2 to report every duplicate pair.
    "minOccurrences": 3
  },
  "rules": {
    "unused-dependencies": "warn",
    "unused-exports": "warn"
  }
}
