# RSP Dashboard local development / LAN example.
# Copy to .env only if you want shell-exported defaults for local scripts.

# Backend mode and bind behavior.
APP_ENV=development
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Local data paths.
DATA_ROOT=data
LOG_DIR=logs

# Frontend/browser API resolution.
# Leave NEXT_PUBLIC_API_URL empty so the browser uses its current hostname plus NEXT_PUBLIC_API_PORT.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_PORT=8000

# Local-only secret examples. Replace for any shared deployment.
ADMIN_SECRET=admin123
JWT_SECRET=change-me-to-a-random-64-character-or-longer-secret-value

# Local frontend origins allowed to call the backend.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Only enable this on a trusted HTTP LAN, never for internet-exposed deployments.
ALLOW_INSECURE_COOKIES=true
